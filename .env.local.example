# ============================================================
# GENIZA — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# ============================================================

# Supabase
# Found at: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Groq
# Found at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# Gmail SMTP
# Create an App Password at: https://myaccount.google.com/apppasswords
# (Requires 2FA enabled on the Gmail account)
GMAIL_USER=geniza.exchange@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Stripe
# Found at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# On Vercel, set this to: https://geniza.exchange (or your Vercel URL)
